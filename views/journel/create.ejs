<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Journal Entry - Journal App</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/loader.css">
    <!-- Quill.js CSS -->
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">
    <style>
        /* Custom Quill styling to fit the app's modern theme */
        .ql-toolbar.ql-snow {
            border-radius: 0.5rem 0.5rem 0 0;
            border-color: #e2e8f0;
            background-color: #f8fafc;
        }

        .ql-container.ql-snow {
            border-radius: 0 0 0.5rem 0.5rem;
            border-color: #e2e8f0;
            min-height: 250px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
        }

        .ql-editor {
            min-height: 250px;
        }
    </style>
</head>

<body class="dashboard-body">
    <!-- Loading Overlay -->
    <div class="page-loader loader-dashboard" id="pageLoader">
        <div class="loader-spinner"></div>
        <p class="loader-text">Loading</p>
    </div>

    <nav class="dashboard-navbar">
        <div class="brand">
            <i class="bi bi-journal-text" style="color: #3b82f6;"></i>
            <span>Journal App</span>
        </div>
        <div class="nav-actions">
            <a href="/dashboard" class="btn-modern btn-modern-ghost">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </nav>

    <div class="dashboard-container mt-4">
        <div class="form-card">
            <div class="form-header">
                <h2 style="font-weight: 700; color: #0f172a; margin: 0; font-size: 1.8rem;">
                    <i class="bi bi-pen me-2" style="color: #3b82f6;"></i> New Journal Entry
                </h2>
                <p style="color: #64748b; margin-top: 0.5rem; margin-bottom: 0;">What's on your mind today?</p>
            </div>

            <form action="/journel/new" method="POST">
                <div class="mb-4">
                    <label class="form-label">Title</label>
                    <input type="text" name="title" class="form-control form-control-lg"
                        placeholder="Enter a descriptive title..." required>
                </div>

                <div class="mb-4">
                    <label class="form-label">Content</label>
                    <!-- Quill editor container -->
                    <div id="editor-container"></div>
                    <!-- Hidden input to store rich text HTML for form submission -->
                    <input type="hidden" name="content" id="content-input" required>
                </div>

                <div class="d-flex gap-3 justify-content-end mt-5">
                    <a href="/dashboard" class="btn-modern btn-modern-outline" style="text-decoration: none;">Cancel</a>
                    <button type="submit" class="btn-modern btn-modern-primary">
                        <i class="bi bi-check2-circle"></i> Save Entry
                    </button>
                </div>
            </form>
        </div>
    </div>

</body>

<!-- Quill.js JS -->
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<script>
    // Initialize Quill editor
    const quill = new Quill('#editor-container', {
        theme: 'snow',
        placeholder: 'Write your thoughts here...',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike'],        // toggled buttons
                ['blockquote', 'code-block'],
                [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                [{ 'align': [] }],
                ['link'],
                ['clean']                                         // remove formatting button
            ]
        }
    });

    // Handle form submission
    const form = document.querySelector('form');
    form.addEventListener('submit', function (e) {
        // Prevent default submission to first ensure content is populated
        e.preventDefault();

        // Populate hidden input with HTML content from Quill
        const contentInput = document.getElementById('content-input');
        const quillHtml = quill.getSemanticHTML();

        // Add basic validation to ensure it's not empty text
        if (quill.getText().trim().length === 0) {
            alert('Journal content cannot be empty.');
            return;
        }

        contentInput.value = quillHtml;

        // Submit the form programmatically
        form.submit();
    });
</script>

<script src="/js/loader.js"></script>

</html>

<%- include('../partials/footer') %>